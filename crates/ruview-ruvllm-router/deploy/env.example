# Router listens on these ports
RUVIEW_ROUTER_GRPC_LISTEN=0.0.0.0:50060
RUVIEW_ROUTER_HTTP_LISTEN=0.0.0.0:8882

# Comma-separated backends: addr:port or addr:port:model
# Both H10H nodes — cluster-3 runs llama3.2:1b, v0 runs llama3.2:1b
RUVIEW_ROUTER_BACKENDS=100.73.75.53:50058,100.77.59.83:50058

# Health check interval in seconds
RUVIEW_ROUTER_HEALTH_SEC=30

RUVIEW_ROUTER_LOG=info
