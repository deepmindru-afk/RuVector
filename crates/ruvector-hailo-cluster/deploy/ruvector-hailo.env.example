# Example environment file for ruvector-hailo-worker.
# Copy to /etc/ruvector-hailo.env and customise.
# The systemd unit reads this via EnvironmentFile=-.

# Listen address. 0.0.0.0:50051 is the cluster default; override to
# 127.0.0.1:N if you only want local clients, or to a tailnet-only IP
# (`tailscale ip -4` on the host) if you want tailnet-only access.
RUVECTOR_WORKER_BIND=0.0.0.0:50051

# Path to the directory containing the model artifacts. Two layouts work
# (worker auto-detects which is present):
#
#   NPU path (iter 167, requires --features hailo + Hailo-8 NPU):
#     model_dir/model.hef
#     model_dir/vocab.txt
#     model_dir/special_tokens.json
#
#   CPU fallback (iter 134, requires --features cpu-fallback):
#     model_dir/model.safetensors
#     model_dir/tokenizer.json
#     model_dir/config.json
#
# Run deploy/download-cpu-fallback-model.sh to fetch the cpu-fallback
# trio with sha256-pinned downloads (~91 MB total).
# See crates/ruvector-hailo/models/README.md for the compile recipe.
RUVECTOR_MODEL_DIR=/var/lib/ruvector-hailo/model

# Tracing filter — info is the production default; ruvector_hailo_worker=debug
# turns on per-RPC spans without flooding upstream noise.
RUST_LOG=info,ruvector_hailo_cluster=info,ruvector_hailo=info

# Iter 147 — parallel inference pool size for the cpu-fallback path.
# Each slot holds an independent candle BertModel; the OS dedupes the
# 90 MB safetensors mmap so memory cost is ~100 MB total at pool=4
# (vs 90 MB at pool=1). Set to your physical core count for max throughput.
# Pi 5 (4 cores): 4. Single-board with 2 cores: 2. Default 1 (backward compat).
# No-op when --features cpu-fallback isn't built in.
RUVECTOR_CPU_FALLBACK_POOL_SIZE=4
