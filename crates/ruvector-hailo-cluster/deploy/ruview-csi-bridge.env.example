# ruview-csi-bridge — environment template (ADR-171, iter 126).
#
# Drop edited copy at /etc/ruvector-csi-bridge.env and the systemd unit
# will source it. Comment + quoting rules are systemd EnvironmentFile=
# conventions (not bash).

# ---- Required ----

# UDP bind address for incoming ADR-018 binary CSI frames. RuView's
# stock ESP32 CSI nodes broadcast to 5005 by default. Use 0.0.0.0:N
# to listen on all interfaces, or pin to a specific NIC IP.
RUVECTOR_CSI_LISTEN=0.0.0.0:5005

# Cluster sink — comma-separated host:port list of the hailo-backend
# workers' gRPC endpoints. Same flag as embed/bench --workers.
RUVECTOR_CSI_WORKERS=100.77.59.83:50051,100.77.59.84:50051

# sha256 hex of the cluster's HEF + vocab. Required by the §2a gate;
# unset means "no enforcement", which the gate refuses unless
# RUVECTOR_CSI_EXTRA_ARGS includes --allow-empty-fingerprint.
RUVECTOR_CSI_FINGERPRINT=

# ---- Optional ----

# Extra args appended verbatim to ExecStart. Useful for:
#   --quiet                   (suppress informational stderr)
#   --allow-empty-fingerprint (legacy fleet without an HEF)
#   --dim 384                 (non-MiniLM cluster dim)
#
# TLS / mTLS (requires `--features tls` build):
#   --tls-ca /etc/ruvector-csi/ca.pem
#   --tls-client-cert /etc/ruvector-csi/client.pem
#   --tls-client-key  /etc/ruvector-csi/client.key
RUVECTOR_CSI_EXTRA_ARGS=
